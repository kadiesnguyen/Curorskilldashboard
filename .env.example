# Copy: cp .env.example .env

# Dashboard UI port on host
DASHBOARD_PORT=3847

# Absolute path to your home (must match paths inside data/store.json)
HOST_HOME=/home/you
PROJECTS_ROOT=/home/you/Documents/GitHub

# mem0
MEM0_USER_ID=default
MEM0_QDRANT_HOST=host.docker.internal
MEM0_QDRANT_PORT=6333
MEM0_COLLECTION=mem0

# 1 = bootstrap data/store.json from Docker template (first install only)
USE_DOCKER_STORE=0

# Optional: run bundled Qdrant via compose profile bundled-qdrant
# QDRANT_PORT=6333
