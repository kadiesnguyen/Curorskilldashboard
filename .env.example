# Copy: cp .env.example .env

# Dashboard UI port on host
DASHBOARD_PORT=3847

# Qdrant port on host (mem0 storage)
QDRANT_PORT=6333

# mem0 user scope (match Cursor MCP MEM0_USER_ID)
MEM0_USER_ID=default
MEM0_COLLECTION=mem0

# Host paths mounted into container
# Linux/macOS defaults below; adjust for your machine
CURSOR_HOME=${HOME}/.cursor
AGENTS_HOME=${HOME}/.agents
PROJECTS_ROOT=${HOME}/Documents/GitHub
