# Copy: cp .env.example .env

DASHBOARD_PORT=3847

# Absolute home on host — paths in data/store.json must match
HOST_HOME=/home/kadiess
PROJECTS_ROOT=/home/kadiess/Documents/GitHub

# mem0 — dùng Qdrant đã chạy sẵn trên máy (container "qdrant")
MEM0_USER_ID=kadiess
MEM0_QDRANT_HOST=host.docker.internal
MEM0_QDRANT_PORT=6333
MEM0_COLLECTION=mem0

# Giữ store.json hiện có (không dùng template Docker)
USE_DOCKER_STORE=0

# Chỉ bật khi muốn compose tự chạy Qdrant: docker compose --profile bundled-qdrant up -d
# QDRANT_PORT=6333
